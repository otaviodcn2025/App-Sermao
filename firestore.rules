rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApproved() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email', 'role', 'approved', 'createdAt']) &&
               data.keys().size() == 6 &&
               data.uid == request.auth.uid &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.email is string && data.email.size() <= 255 &&
               data.role in ['admin', 'user'] &&
               data.approved is bool &&
               data.createdAt is number;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    (incoming().email == 'pastorotavio@gmail.com' ? (incoming().role == 'admin' && incoming().approved == true) : (incoming().role == 'user' && incoming().approved == false));
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid && 
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt &&
                    (incoming().email == 'pastorotavio@gmail.com' ? 
                      (incoming().role == 'admin' && incoming().approved == true) : 
                      (incoming().role == existing().role && incoming().approved == existing().approved && (incoming().diff(existing()).affectedKeys().hasOnly(['name']) || incoming().diff(existing()).affectedKeys().size() == 0))
                    )
                  ) ||
                  (isAdmin() && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasAny(['role', 'approved']));
      allow delete: if isAdmin();
    }

    // Sermons Collection
    match /sermons/{sermonId} {
      function isValidSermon(data) {
        return data.keys().hasAll(['id', 'userId', 'title', 'content', 'createdAt', 'updatedAt']) &&
               data.id == sermonId &&
               data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 255 &&
               data.content is string && data.content.size() <= 1048576 &&
               data.createdAt is number &&
               data.updatedAt is number &&
               (!('seriesId' in data) || data.seriesId == null || (data.seriesId is string && isValidId(data.seriesId))) &&
               (!('tags' in data) || data.tags is list);
      }

      allow list: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
      allow get: if true; // Permite visualização pública via link direto
      allow create: if (isApproved() || isAdmin()) && 
                    isValidSermon(incoming()) && 
                    isValidId(sermonId) &&
                    incoming().createdAt <= request.time.toMillis();
      allow update: if (isApproved() || isAdmin()) && 
                    resource.data.userId == request.auth.uid &&
                    isValidSermon(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().id == existing().id &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt >= existing().updatedAt;
      allow delete: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
    }

    // Resources Collection
    match /resources/{resourceId} {
      function isValidResource(data) {
        return data.keys().hasAll(['id', 'userId', 'title', 'type', 'createdAt']) &&
               data.id == resourceId &&
               data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 255 &&
               data.type in ['pdf', 'link', 'epub'] &&
               data.createdAt is number &&
               // Optional fields validation
               (!('lastReadPosition' in data) || data.lastReadPosition is number) &&
               (!('highlights' in data) || data.highlights is list) &&
               (!('extractedText' in data) || data.extractedText is string) &&
               (!('summary' in data) || data.summary is string) &&
               (!('tags' in data) || data.tags is list) &&
               (!('seriesId' in data) || data.seriesId == null || (data.seriesId is string && isValidId(data.seriesId)));
      }

      allow list: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
      allow get: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
      allow create: if (isApproved() || isAdmin()) && isValidResource(incoming()) && isValidId(resourceId);
      allow update: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid && isValidResource(incoming());
      allow delete: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
    }

    // Series Collection
    match /series/{seriesId} {
      function isValidSeries(data) {
        return data.keys().hasAll(['id', 'userId', 'title', 'createdAt']) &&
               data.id == seriesId &&
               data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 255 &&
               data.createdAt is number &&
               (!('description' in data) || data.description is string) &&
               (!('color' in data) || data.color is string) &&
               (!('tags' in data) || data.tags is list);
      }

      allow list: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
      allow get: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
      allow create: if (isApproved() || isAdmin()) && isValidSeries(incoming()) && isValidId(seriesId);
      allow update: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid && isValidSeries(incoming());
      allow delete: if (isApproved() || isAdmin()) && resource.data.userId == request.auth.uid;
    }
  }
}
