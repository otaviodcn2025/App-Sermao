{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role", "approved", "createdAt"]
    },
    "Sermon": {
      "title": "Sermon",
      "description": "Sermon document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "seriesId": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "content", "createdAt", "updatedAt"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Book or reference document extracted text",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "link", "epub"] },
        "url": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "seriesId": { "type": "string" },
        "extractedText": { "type": "string" },
        "summary": { "type": "string" },
        "lastReadPosition": { "type": "number" },
        "highlights": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "startIndex": { "type": "number" },
              "endIndex": { "type": "number" },
              "color": { "type": "string" },
              "createdAt": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "type", "createdAt"]
    },
    "Series": {
      "title": "Series",
      "description": "Sermon series grouping",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "tags": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/sermons/{sermonId}": {
      "schema": "Sermon",
      "description": "Sermon documents"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Stored books and reference texts"
    },
    "/series/{seriesId}": {
      "schema": "Series",
      "description": "Message series"
    }
  }
}
