{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role", "approved", "createdAt"]
    },
    "Sermon": {
      "title": "Sermon",
      "description": "Sermon document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "content", "createdAt", "updatedAt"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Book or reference document extracted text",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "link"] },
        "url": { "type": "string" },
        "extractedText": { "type": "string" },
        "summary": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/sermons/{sermonId}": {
      "schema": "Sermon",
      "description": "Sermon documents"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Stored books and reference texts"
    }
  }
}
